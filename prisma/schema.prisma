generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Firm {
  id           String           @id @default(cuid())
  name         String           @unique
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  clients      Client[]
  memberships  FirmMembership[]
  settings     FirmSetting[]
  ruleSettings FirmSettings?
  invitations  Invitation[]
  matters      Matter[]
  templates    MatterTemplate[]
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  role          FirmRole        
  password      String?
  accounts      Account[]
  membership    FirmMembership?
  sessions      Session[]
}

model FirmMembership {
  id        String   @id @default(cuid())
  firmId    String
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  role      FirmRole
  firm      Firm     @relation(fields: [firmId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([firmId, userId])
}

model Invitation {
  id         String    @id @default(cuid())
  email      String
  firmId     String
  token      String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  role       FirmRole
  firm       Firm      @relation(fields: [firmId], references: [id], onDelete: Cascade)
}

model Client {
  id          String   @id @default(cuid())
  name        String
  companyName String
  logoUrl     String
  userId      String?
  firmId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  firm        Firm     @relation(fields: [firmId], references: [id], onDelete: Cascade)
  matters     Matter[]
}

model Matter {
  id              String           @id @default(cuid())
  title           String
  blurb           String
  engagementDate  DateTime
  amountPaid      Int
  dueDate         DateTime
  lastActivityAt  DateTime
  archivedAt      DateTime?
  userId		  String?
  firmId          String
  clientId        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  closedAt        DateTime?
  groupProgress   Json?
  checklistGroups ChecklistGroup[]
  checklistSteps  ChecklistStep[]
  client          Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  firm            Firm             @relation(fields: [firmId], references: [id], onDelete: Cascade)
}

model MatterTemplate {
  id        String          @id @default(cuid())
  name      String
  sortOrder Int             @default(0)
  userId    String?
  firmId    String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  firm      Firm            @relation(fields: [firmId], references: [id], onDelete: Cascade)
  groups    TemplateGroup[]
  steps     TemplateStep[]
}

model FirmSetting {
  id        String   @id @default(cuid())
  key       String
  value     String
  firmId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  firm      Firm     @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@unique([firmId, key])
}

model FirmSettings {
  id                       String   @id @default(cuid())
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  bottleneckDays           Int      @default(7)
  dueSoonHours             Int      @default(48)
  penaltyIncludeOverdue    Boolean  @default(true)
  penaltyIncludeBottleneck Boolean  @default(true)
  penaltyIncludeAging      Boolean  @default(true)
  maxOpenDays              Int?
  firmId                   String   @unique
  bottleneckNoProgressDays Int      @default(7)
  penaltyBoxOpenDays       Int      @default(40)
  noMovementDays           Int      @default(7)
  defaultGroupExpectedDays Int      @default(7)
  groupGraceDays           Int      @default(2)
  agingDays                Int      @default(30)
  groupTimingEnabled       Boolean  @default(true)
  atRiskStageWindowDays    Int      @default(2)
  firm                     Firm     @relation(fields: [firmId], references: [id], onDelete: Cascade)
}

model ChecklistGroup {
  id                   String          @id @default(cuid())
  title                String
  sortOrder            Int
  indentLevel          Int             @default(0)
  matterId             String
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  expectedDurationDays Int?
  matter               Matter          @relation(fields: [matterId], references: [id], onDelete: Cascade)
  steps                ChecklistStep[]
}

model ChecklistStep {
  id            String          @id @default(cuid())
  label         String
  completed     Boolean         @default(false)
  sortOrder     Int
  indentLevel   Int             @default(0)
  dueDaysOffset Int?
  matterId      String
  groupId       String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  dueAt         DateTime?
  completedAt   DateTime?
  group         ChecklistGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  matter        Matter          @relation(fields: [matterId], references: [id], onDelete: Cascade)
}

model TemplateGroup {
  id                   String         @id @default(cuid())
  title                String
  sortOrder            Int
  indentLevel          Int            @default(0)
  templateId           String
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  expectedDurationDays Int?
  template             MatterTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  steps                TemplateStep[]
}

model TemplateStep {
  id                   String         @id @default(cuid())
  label                String
  sortOrder            Int
  indentLevel          Int            @default(0)
  defaultDueDaysOffset Int?
  templateId           String
  groupId              String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  group                TemplateGroup? @relation(fields: [groupId], references: [id])
  template             MatterTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum FirmRole {
  ADMIN
  ATTORNEY
  STAFF
  READ_ONLY
}
